{
    "name": "damienjolly/habbo-gamedata",
    "description": "Reusable Habbo gamedata domain package for Laravel.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "require": {
        "php": "^8.3",
        "illuminate/database": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Habbo\\Gamedata\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Habbo\\Gamedata\\HabboGamedataServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
